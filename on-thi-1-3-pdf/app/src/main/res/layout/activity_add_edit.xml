<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ga đi"
        android:textColor="#888888"
        android:textSize="13sp" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/etGaDi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập ga đi"
        android:inputType="text"
        android:textSize="16sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ga đến"
        android:textColor="#888888"
        android:textSize="13sp" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/etGaDen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập ga đến"
        android:inputType="text"
        android:textSize="16sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đơn Giá"
        android:textColor="#888888"
        android:textSize="13sp" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/etDonGia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập đơn giá"
        android:inputType="numberDecimal"
        android:textSize="16sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loại Vé"
        android:textColor="#888888"
        android:textSize="13sp" />

    <RadioGroup
        android:id="@+id/rgLoaiVe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbKhuHoi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Khứ Hồi"
            android:buttonTint="@color/purple_700"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/rbMotChieu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:text="Một Chiều"
            android:buttonTint="@color/purple_700"
            android:textSize="15sp" />
    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnAction"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:backgroundTint="@color/purple_700"
            android:text="THÊM"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnQuayVe"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:backgroundTint="@color/purple_700"
            android:text="QUAY VỀ"
            android:textColor="@android:color/white"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>

